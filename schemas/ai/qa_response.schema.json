{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkQaResponse",
  "$defs": {
    "citationLocator": {
      "oneOf": [
        {
          "required": ["pageNo"],
          "not": {
            "anyOf": [
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["slideNo"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["anchorKey"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["startSec", "endSec"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              }
            ]
          }
        }
      ]
    },
    "generationMetadata": {
      "type": "object",
      "required": ["source", "reason", "evidenceTier"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["model", "fallback"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidenceTier": {
          "type": "string",
          "enum": ["original_evidence", "handout_context", "course_prior", "out_of_scope"]
        },
        "handoutContext": {
          "type": "object",
          "properties": {
            "handoutBlockId": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "string",
                  "minLength": 1
                }
              ]
            },
            "outlineKey": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["answerMd", "answerType", "citations", "generationMetadata"],
  "properties": {
    "answerMd": {
      "type": "string",
      "minLength": 1
    },
    "answerType": {
      "type": "string",
      "enum": ["direct_answer", "clarification", "insufficient_evidence"]
    },
    "citations": {
      "type": "array",
        "items": {
          "type": "object",
          "required": ["resourceId", "refLabel"],
          "properties": {
          "resourceId": {
            "type": "integer",
            "minimum": 1
          },
          "pageNo": {
            "type": "integer",
            "minimum": 1
          },
          "slideNo": {
            "type": "integer",
            "minimum": 1
          },
          "anchorKey": {
            "type": "string",
            "minLength": 1
          },
          "startSec": {
            "type": "integer",
            "minimum": 0
          },
          "endSec": {
            "type": "integer",
            "minimum": 0
          },
            "refLabel": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "$ref": "#/$defs/citationLocator"
            }
          ],
          "additionalProperties": false
        }
      },
    "generationMetadata": {
      "$ref": "#/$defs/generationMetadata"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["generationMetadata"],
        "properties": {
          "generationMetadata": {
            "required": ["evidenceTier"],
            "properties": {
              "evidenceTier": {
                "enum": ["handout_context", "course_prior", "out_of_scope"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "citations": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
