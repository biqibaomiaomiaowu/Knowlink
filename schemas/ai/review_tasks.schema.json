{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkReviewTasks",
  "description": "Schema for Cao Le-owned review recommendation strategy. Tasks carry source keys for server-side reverse lookup; AI output must not invent page, slide, anchor, or video timestamp locators.",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "taskKey",
          "taskType",
          "priorityScore",
          "reasonText",
          "recommendedMinutes",
          "knowledgePointKey",
          "sourceQuestionKeys",
          "sourceBlockKey",
          "sourceSegmentKeys",
          "reviewOrder",
          "reasonTags",
          "recommendedAction"
        ],
        "properties": {
          "taskKey": {
            "type": "string",
            "minLength": 1
          },
          "taskType": {
            "type": "string",
            "enum": ["revisit_block", "redo_quiz", "formula_drill"]
          },
          "priorityScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reasonText": {
            "type": "string",
            "minLength": 1
          },
          "recommendedMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "knowledgePointKey": {
            "type": "string",
            "minLength": 1
          },
          "sourceQuestionKeys": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sourceBlockKey": {
            "type": "string",
            "minLength": 1
          },
          "sourceSegmentKeys": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reviewOrder": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "reasonTags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["recent_wrong", "low_mastery", "high_priority", "spacing_review"]
            }
          },
          "recommendedAction": {
            "type": "object",
            "required": ["type", "targetBlockKey", "label"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["revisit_block", "redo_quiz"]
              },
              "targetBlockKey": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
