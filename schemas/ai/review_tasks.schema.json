{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkReviewTasks",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["taskType", "priorityScore", "reasonText", "recommendedMinutes"],
        "properties": {
          "taskType": {
            "type": "string",
            "enum": ["revisit_block", "redo_quiz", "formula_drill"]
          },
          "priorityScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reasonText": {
            "type": "string",
            "minLength": 1
          },
          "recommendedMinutes": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
