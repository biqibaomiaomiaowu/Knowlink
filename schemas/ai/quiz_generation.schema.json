{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkQuizGeneration",
  "description": "Schema for Cao Le-owned quiz generation strategy. Questions carry source keys for server-side reverse lookup; AI output must not invent page, slide, anchor, or video timestamp locators.",
  "type": "object",
  "required": ["quizType", "questions"],
  "properties": {
    "quizType": {
      "type": "string",
      "enum": ["block_check", "chapter_review", "exam_drill"]
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "questionKey",
          "questionType",
          "stemMd",
          "options",
          "correctAnswer",
          "explanationMd",
          "difficultyLevel",
          "knowledgePointKey",
          "knowledgePointName",
          "sourceBlockKey",
          "sourceSegmentKeys"
        ],
        "properties": {
          "questionKey": {
            "type": "string",
            "minLength": 1
          },
          "questionType": {
            "type": "string",
            "enum": ["single_choice"]
          },
          "stemMd": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "correctAnswer": {
            "type": "string",
            "enum": ["A", "B", "C", "D"]
          },
          "explanationMd": {
            "type": "string",
            "minLength": 1
          },
          "difficultyLevel": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "knowledgePointKey": {
            "type": "string",
            "minLength": 1
          },
          "knowledgePointName": {
            "type": "string",
            "minLength": 1
          },
          "sourceBlockKey": {
            "type": "string",
            "minLength": 1
          },
          "sourceSegmentKeys": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
