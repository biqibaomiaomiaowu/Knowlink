{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkHandoutBlocks",
  "description": "Legacy Week 1 whole-handout schema kept for historical citation contract tests. Week 2+ video-first lazy generation uses schemas/ai/handout_outline.schema.json and schemas/ai/handout_block.schema.json as the authoritative handout generation schemas.",
  "$defs": {
    "citationLocator": {
      "oneOf": [
        {
          "required": ["pageNo"],
          "not": {
            "anyOf": [
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["slideNo"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["anchorKey"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        },
        {
          "required": ["startSec", "endSec"],
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              }
            ]
          }
        }
      ]
    }
  },
  "type": "object",
  "required": ["title", "summary", "blocks"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "summary", "contentMd", "estimatedMinutes", "knowledgePointIds", "citations"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "contentMd": {
            "type": "string",
            "minLength": 1
          },
          "estimatedMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "knowledgePointIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "citations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["resourceId", "refLabel"],
              "properties": {
                "resourceId": {
                  "type": "integer",
                  "minimum": 1
                },
                "segmentId": {
                  "type": "integer",
                  "minimum": 1
                },
                "pageNo": {
                  "type": "integer",
                  "minimum": 1
                },
                "slideNo": {
                  "type": "integer",
                  "minimum": 1
                },
                "anchorKey": {
                  "type": "string",
                  "minLength": 1
                },
                "startSec": {
                  "type": "integer",
                  "minimum": 0
                },
                "endSec": {
                  "type": "integer",
                  "minimum": 0
                },
                "refLabel": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "allOf": [
                {
                  "$ref": "#/$defs/citationLocator"
                }
              ],
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
