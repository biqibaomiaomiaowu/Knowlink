{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowLinkNormalizedDocument",
  "$defs": {
    "pdfSegment": {
      "allOf": [
        {
          "properties": {
            "segmentType": {
              "enum": ["pdf_page_text", "ocr_text", "formula", "image_caption"]
            }
          }
        },
        {
          "required": ["pageNo"]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["sectionPath"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        }
      ]
    },
    "pptxSegment": {
      "allOf": [
        {
          "properties": {
            "segmentType": {
              "enum": ["ppt_slide_text", "ocr_text", "formula", "image_caption"]
            }
          }
        },
        {
          "required": ["slideNo"]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["sectionPath"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        }
      ]
    },
    "docxSegment": {
      "allOf": [
        {
          "properties": {
            "segmentType": {
              "enum": ["docx_block_text", "ocr_text", "formula", "image_caption"]
            }
          }
        },
        {
          "required": ["sectionPath"]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["startSec"]
              },
              {
                "required": ["endSec"]
              }
            ]
          }
        }
      ]
    },
    "mp4Segment": {
      "allOf": [
        {
          "properties": {
            "segmentType": {
              "enum": ["video_caption", "ocr_text", "formula", "image_caption"]
            }
          }
        },
        {
          "required": ["startSec", "endSec"]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["sectionPath"]
              }
            ]
          }
        }
      ]
    },
    "srtSegment": {
      "allOf": [
        {
          "properties": {
            "segmentType": {
              "const": "video_caption"
            }
          }
        },
        {
          "required": ["startSec", "endSec"]
        },
        {
          "not": {
            "anyOf": [
              {
                "required": ["pageNo"]
              },
              {
                "required": ["slideNo"]
              },
              {
                "required": ["anchorKey"]
              },
              {
                "required": ["sectionPath"]
              },
              {
                "required": ["imageKey"]
              },
              {
                "required": ["formulaText"]
              },
              {
                "required": ["bboxJson"]
              }
            ]
          }
        }
      ]
    }
  },
  "type": "object",
  "required": ["resourceType", "segments"],
  "properties": {
    "resourceType": {
      "type": "string",
      "enum": ["mp4", "pdf", "srt", "pptx", "docx"]
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segmentKey", "segmentType", "orderNo", "textContent"],
        "properties": {
          "segmentKey": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$"
          },
          "segmentType": {
            "type": "string",
            "enum": [
              "video_caption",
              "pdf_page_text",
              "ppt_slide_text",
              "docx_block_text",
              "ocr_text",
              "formula",
              "image_caption"
            ]
          },
          "orderNo": {
            "type": "integer",
            "minimum": 1
          },
          "textContent": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "[\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F-\\u009F\\uFFFD\\uFFFF]"
            }
          },
          "startSec": {
            "type": "integer",
            "minimum": 0
          },
          "endSec": {
            "type": "integer",
            "minimum": 0
          },
          "pageNo": {
            "type": "integer",
            "minimum": 1
          },
          "slideNo": {
            "type": "integer",
            "minimum": 1
          },
          "anchorKey": {
            "type": "string",
            "minLength": 1
          },
          "sectionPath": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "imageKey": {
            "type": "string",
            "minLength": 1
          },
          "formulaText": {
            "type": "string",
            "minLength": 1
          },
          "bboxJson": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "pdf"
          }
        }
      },
      "then": {
        "properties": {
          "segments": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/pdfSegment"
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "pptx"
          }
        }
      },
      "then": {
        "properties": {
          "segments": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/pptxSegment"
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "docx"
          }
        }
      },
      "then": {
        "properties": {
          "segments": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/docxSegment"
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "mp4"
          }
        }
      },
      "then": {
        "properties": {
          "segments": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/mp4Segment"
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "srt"
          }
        }
      },
      "then": {
        "properties": {
          "segments": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/srtSegment"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
