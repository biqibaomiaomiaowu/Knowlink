KNOWLINK_APP_NAME=KnowLink API
KNOWLINK_ENV=development
KNOWLINK_HOST=0.0.0.0
KNOWLINK_PORT=8000
KNOWLINK_DEMO_TOKEN=knowlink-demo-token
KNOWLINK_DEMO_USER_ID=1
KNOWLINK_DEMO_USER_NAME=KnowLink Demo
KNOWLINK_DATABASE_URL=postgresql+asyncpg://knowlink:knowlink@postgres:5432/knowlink
KNOWLINK_REDIS_URL=redis://redis:6379/0
KNOWLINK_MINIO_ENDPOINT=minio:9000
KNOWLINK_MINIO_ACCESS_KEY=minioadmin
KNOWLINK_MINIO_SECRET_KEY=minioadmin
KNOWLINK_ENABLE_MARKITDOWN_OCR=false
KNOWLINK_ENABLE_MINERU=false
KNOWLINK_MINERU_TOKEN=
KNOWLINK_MINERU_BASE_URL=https://mineru.net
KNOWLINK_MINERU_MODEL_VERSION=vlm
KNOWLINK_MINERU_LANGUAGE=ch
KNOWLINK_MINERU_IS_OCR=true
KNOWLINK_MINERU_ENABLE_FORMULA=true
KNOWLINK_MINERU_ENABLE_TABLE=true
KNOWLINK_MINERU_TIMEOUT_SEC=30
KNOWLINK_MINERU_POLL_INTERVAL_SEC=3
KNOWLINK_MINERU_MAX_WAIT_SEC=180
KNOWLINK_MINERU_MAX_RETRIES=2
KNOWLINK_MINERU_DOWNLOAD_USE_PROXY=false
KNOWLINK_ENABLE_VIVO_OCR=false
KNOWLINK_VIVO_APP_ID=
KNOWLINK_VIVO_APP_KEY=
KNOWLINK_VIVO_BASE_URL=https://api-ai.vivo.com.cn
KNOWLINK_VIVO_OCR_TIMEOUT_SEC=10
KNOWLINK_VIVO_OCR_BUSINESS_ID=
KNOWLINK_ENABLE_VIVO_ASR=false
KNOWLINK_VIVO_ASR_ENGINE_ID=fileasrrecorder
KNOWLINK_VIVO_ASR_USER_ID=
KNOWLINK_VIVO_ASR_CLIENT_VERSION=unknown
KNOWLINK_VIVO_ASR_PACKAGE=unknown
KNOWLINK_VIVO_ASR_TIMEOUT_SEC=30
KNOWLINK_VIVO_ASR_POLL_INTERVAL_SEC=3
KNOWLINK_VIVO_ASR_MAX_WAIT_SEC=600
KNOWLINK_VIVO_ASR_RUN_PATH=/lasr/run
KNOWLINK_ENABLE_VIVO_VISION=false
KNOWLINK_VIVO_VISION_MODEL=Doubao-Seed-2.0-mini
KNOWLINK_VIVO_VISION_TIMEOUT_SEC=20
KNOWLINK_VIVO_VISION_BATCH_SIZE=2
KNOWLINK_VIVO_OUTLINE_MODEL=Doubao-Seed-2.0-mini
KNOWLINK_VIVO_HANDOUT_BLOCK_MODEL=Doubao-Seed-2.0-pro
KNOWLINK_VIVO_HANDOUT_TIMEOUT_SEC=40
KNOWLINK_VIVO_HANDOUT_BLOCK_TIMEOUT_SEC=120
KNOWLINK_ENABLE_VIVO_EMBEDDING=false
KNOWLINK_VIVO_EMBEDDING_MODEL=m3e-base
KNOWLINK_VIVO_EMBEDDING_TIMEOUT_SEC=10
